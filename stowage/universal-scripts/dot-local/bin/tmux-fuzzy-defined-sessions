#!/usr/bin/env bash
set -u

# open a tmux session out of our well-defined session options

INIT_QUERY=${1:-}

DEFINED_SESSIONS=(
	"default"
	"updates"
	"config"
	"config-work"
)

main() {
	local session_name
	session_name=$(
		IFS=$'\n'; echo "${DEFINED_SESSIONS[*]}" \
		| fzf --no-hscroll --ansi --no-multi -q "$INIT_QUERY"
	)

	case "$session_name" in
		"default")
			tmux-engage-basic-session "$HOME/mine" "default"
			;;
		"config")
			tmux-engage-editor-session "$HOME/config"
			;;
		"config-work")
			tmux-engage-editor-session "$HOME/config-work"
			;;
		"updates")
			tmux-engage-updates-session
			;;
		*)
			local err_msg
			err_msg="Received session name \"$session_name\" was not configured as a "
			err_msg+=" defined tmux session."
			_ltz_print_error "$err_msg"
			return 1
			;;
	esac
}
main
